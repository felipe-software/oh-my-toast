{
    "compilerOptions": {
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "jsx": "react-jsx",
        "lib": ["ES2022", "DOM"],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "noEmit": true,
        "rootDir": "src",
        "skipLibCheck": true,
        "strict": true,
        "target": "ES2022"
    },
    "include": ["src/**/*.ts", "src/**/*.tsx"],
    "exclude": ["lib", "node_modules", "example"]
}
